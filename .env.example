# ── Qwen Cloud (DashScope, OpenAI-compatible endpoint) ────────
# Optional — only needed for `--transport live`. The default `fake` transport
# is fully offline and needs no key at all (see README "Quickstart").
# Get from: https://bailian.console.aliyun.com/ → API-KEY management
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# ── Runtime paths (optional overrides) ─────────────────────────
# Where job state / sqlite db is written. Defaults to ./var
# FORESHADOW_HOME=./var
# Override the bundled seed incidents directory (advanced/testing only).
# FORESHADOW_SEEDS=./seeds
# Override the committed replay fixture cache (advanced/testing only).
# FORESHADOW_FIXTURES=./fixtures/cache
# Force the hero render tier to the cheaper fallback model.
# FORESHADOW_HERO_MODEL=wan2.6-i2v-flash
